syntax on
set number
set clipboard+=unnamedplus
set relativenumber
set mouse=a
set smartindent expandtab autotab
set shiftwidth=2 softtabstop=2 tabstop=2
set wildmenu
set undodir=~/.vim/undo-dir
set undofile
set incsearch
set scrolloff=5
set ignorecase
set smartcase
set nowrap
let g:netrw_liststyle = 3
